# Copy to .env in this folder (artifacts/api-server/) — never commit .env
PORT=8080
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Session signing (required in production). In NODE_ENV=development the server uses an insecure default if unset.
SESSION_SECRET=replace-with-random-32-char-secret
# Optional if SESSION_SECRET is set (server derives a stable JWT key). Prefer setting explicitly (≥32 chars).
JWT_SECRET=replace-with-at-least-32-characters-long-secret

# Comma-separated frontend origins (Vercel + local)
# Example for this project:
# FRONTEND_ORIGINS=https://securepool-usdtluck.vercel.app,http://localhost:5173
FRONTEND_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Deposit screenshots (default: repo artifacts/api-server/uploads). On Railway, add a volume or files disappear on redeploy.
# Example: mount volume at /data/uploads, then in Variables set UPLOAD_DIR=/data/uploads
# UPLOAD_DIR=/data/uploads

# Gmail SMTP (required for signup / OTP emails)
# Railway: Project → your API service → Variables → add BOTH lines exactly (no quotes in the value box).
# Google Account → Security → 2-Step Verification ON → App passwords → create "Mail" → copy 16 chars.
SMTP_USER=youremail@gmail.com
# Paste with or without spaces; server strips spaces before Gmail auth.
SMTP_PASS=your-16-char-app-password
# Aliases (same effect if you prefer these names):
# GMAIL_USER=youremail@gmail.com
# GMAIL_APP_PASSWORD=your-16-char-app-password
EMAIL_FROM="SecurePool <youremail@gmail.com>"
# Optional: force Gmail SMTP profile — `service` (Nodemailer "gmail" preset) or `465` (smtp.gmail.com:465 TLS).
# Unset = try service first, then 465, at startup (Railway may block one path).
# SMTP_GMAIL_TRANSPORT=service
# SMTP_GMAIL_TRANSPORT=465

# Draw summary emails to admin (optional; falls back to SMTP_USER)
# ADMIN_EMAIL=you@gmail.com

# Extra powers in admin UI (comma-separated user ids). Default includes 1.
# SUPER_ADMIN_USER_IDS=1

# Skip automatic SQL on boot (only if you manage DB manually)
# SKIP_DB_MIGRATIONS=1

# Allow boot even if DB migrations fail (NOT recommended for production unless debugging)
# ALLOW_DEGRADED_STARTUP=1

# Force API maintenance mode (returns 503 for /api)
# API_MAINTENANCE_MODE=1

# Optional: auto-create the first admin on a totally empty/fresh database (Railway)
# BOOTSTRAP_ADMIN_EMAIL=you@example.com
# BOOTSTRAP_ADMIN_PASSWORD='choose-a-strong-password'
# BOOTSTRAP_ADMIN_NAME=Admin

# --- Mini games (Risk Wheel, Treasure Hunt, Lucky Numbers, Hi-Lo, Mega Draw)
# Needs lib/db/migrations/0053_arcade_mega_treasure_hilo.sql applied once (mega_draw_*, arcade sessions, arcade_rounds.payload).
# Apply manually before first deploy, or rely on server startup (runPendingSqlMigrations) when SKIP_DB_MIGRATIONS is unset.
# From repo root with DATABASE_URL set:  pnpm run migrate:sql

# --- One-shot: wipe DB + create a single new admin (run after `pnpm build` in this package)
# FRESH_CONFIRM=YES
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=your-secure-password
# ADMIN_NAME=Admin

# --- Arcade smoke tests (scripts/smoke-arcade-*.mjs; API must be running for HTTP)
# API_BASE_URL=http://127.0.0.1:8080
# ARCADE_SMOKE_PUBLIC_ONLY=1
# ARCADE_SMOKE_EMAIL=you@example.com
# ARCADE_SMOKE_PASSWORD=your-password
# ARCADE_SMOKE_SKIP_PLAY=1
# ARCADE_SMOKE_BET=1
# ARCADE_SMOKE_GAME=spin_wheel
# Dev only — resets first admin password (requires `pnpm run build`); never use on production DB:
# ARCADE_SMOKE_DEV_RESET_ADMIN=1
# Then: ARCADE_SMOKE_PASSWORD='your-min-8-chars' pnpm run smoke:arcade-http:e2e

