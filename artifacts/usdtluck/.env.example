# Copy to .env.local (Vite) — never commit real secrets
# API origin for production static hosting (Vercel). Dev uses Vite proxy → leave unset locally.
# VITE_API_URL=https://your-api.up.railway.app
# PKR shown next to USDT (optional override; default 278.6 in code)
# VITE_PKR_PER_USDT=278.6
# USDT (TRC20) address shown on Wallet → Deposit and Dashboard embed (optional; has safe default in code)
# VITE_PLATFORM_USDT_ADDRESS=TBjGU8jfZvsfDVPpjJXVb47khVyKjQqjqp
